# Championship Sudoku — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env or .env.local to git.

# Supabase (shared with Championship Chess)
VITE_SUPABASE_URL=https://ahsullbcdrekmribkcbm.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...replace_with_real_anon_key

# Optional: override project ref for CLI
VITE_SUPABASE_PROJECT_ID=ahsullbcdrekmribkcbm

# Optional: link to Championship Chess in the navbar (UTM se añade en código)
# VITE_CHESS_APP_URL=https://your-chess-app.vercel.app

# Optional: Casual Games marketing hub (enlace "Hub" en la barra)
# VITE_HUB_URL=https://casualgames-hub.vercel.app

# Feature flags (omitir o "1" = activo; "0" = desactiva en build)
# VITE_FEATURE_HINTS=1
# VITE_FEATURE_DAILY=1
